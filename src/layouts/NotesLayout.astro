---
import Layout from './Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import TOC from '../components/TOC.astro';

const { title, headings = [] } = Astro.props;
---

<Layout title={title}>
  <div class="notes-container container">
    <Sidebar />
    <main class="notes-content animate-fade-in">
      <slot />
    </main>
    <div class="notes-toc">
      {headings.length > 0 && <TOC headings={headings} />}
    </div>
  </div>
</Layout>

<style>
  .notes-container {
    display: flex;
    gap: 3rem;
    padding-top: 1rem;
    align-items: flex-start;
  }

  .notes-content {
    flex: 1;
    max-width: 700px;
    min-width: 0;
    padding-bottom: 4rem;
  }

  .notes-toc {
    width: 220px;
    flex-shrink: 0;
    display: none;
  }

  @media (min-width: 1024px) {
    .notes-toc {
      display: block;
    }
  }

  @media (max-width: 768px) {
    .notes-container {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
