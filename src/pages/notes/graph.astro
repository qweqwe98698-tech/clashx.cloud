---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('notes');

// Build Nodes
const nodes = allNotes.map(n => ({
  id: n.id,
  name: n.data.title,
  val: 1
}));

// Build Links
const links = [];
allNotes.forEach(n => {
  if (!n.body) return;
  // Match [[...]]
  const matches = [...n.body.matchAll(/\[\[(.*?)\]\]/g)];
  matches.forEach(match => {
    const targetTitleOrId = match[1];
    // Find target by exact title or id
    const targetNode = allNotes.find(t => t.data.title === targetTitleOrId || t.id === targetTitleOrId);
    if (targetNode) {
      links.push({
        source: n.id,
        target: targetNode.id
      });
    }
  });
});

const graphData = JSON.stringify({ nodes, links });
---

<Layout title="知识星空 - 数字花园">
  <div class="graph-wrapper">
    <div class="graph-header">
      <h1>🌌 知识星空</h1>
      <p>拖拽节点探索知识的引力。滚动鼠标缩放。</p>
      <a href="/notes" class="btn-secondary" style="font-size: 0.8rem; padding: 0.5rem 1rem; margin-top: 1rem; display: inline-block;">返回知识库</a>
    </div>
    <div id="2d-graph" class="graph-container"></div>
  </div>
</Layout>

<script is:inline src="//unpkg.com/force-graph"></script>
<script is:inline define:vars={{ graphData }}>
  document.addEventListener('DOMContentLoaded', () => {
    const data = JSON.parse(graphData);
    const elem = document.getElementById('2d-graph');
    
    // Determine colors based on current theme (fallback for light mode)
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    const textColor = isDark ? 'rgba(255,255,255,0.8)' : 'rgba(0,0,0,0.8)';
    const linkColor = isDark ? 'rgba(255,255,255,0.2)' : 'rgba(0,0,0,0.2)';
    // To make it look like a real starry night, let's force dark background for the canvas container via CSS, or just match theme
    const bgColor = isDark ? '#000000' : '#fbfbfd';

    const Graph = ForceGraph()(elem)
      .graphData(data)
      .backgroundColor(bgColor)
      .nodeLabel('name')
      .nodeAutoColorBy('id')
      .linkColor(() => linkColor)
      .onNodeClick(node => {
        window.location.href = `/notes/${node.id}`;
      });

    // Handle resize
    const resize = () => {
      Graph.width(elem.clientWidth).height(elem.clientHeight);
    };
    window.addEventListener('resize', resize);
    
    // Initial size
    setTimeout(resize, 100);
    
    // Also re-init colors on astro:after-swap if needed, but since we use Layout it might full reload
  });
</script>

<style>
  /* Override Layout constraints for full screen graph */
  :global(main) {
    max-width: none !important;
    padding: 0 !important;
  }
  
  .graph-wrapper {
    position: relative;
    width: 100vw;
    height: calc(100vh - 64px); /* Subtract navbar */
    margin-left: calc(-50vw + 50%);
    margin-top: -100px; /* Counter Layout padding-top */
    overflow: hidden;
    background: var(--bg-color);
  }

  .graph-header {
    position: absolute;
    top: 2rem;
    left: 2rem;
    z-index: 10;
    pointer-events: none;
    background: var(--card-bg);
    padding: 1.5rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--card-border);
    box-shadow: var(--shadow-md);
  }

  .graph-header h1 {
    margin: 0;
    font-size: 1.8rem;
  }

  .graph-header p {
    color: var(--text-secondary);
    margin: 0.5rem 0;
    font-size: 0.9rem;
  }
  
  .graph-header a {
    pointer-events: auto;
  }

  .graph-container {
    width: 100%;
    height: 100%;
  }
</style>
