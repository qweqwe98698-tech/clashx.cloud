---
const currentYear = new Date().getFullYear();
---
<footer class="footer">
  <div class="container">
    <div class="footer-links">
      <a href="/terms">服务条款</a>
      <a href="/privacy">隐私政策</a>
      <a href="/about">关于本站</a>
      <a href="/sitemap-index.xml">站点地图</a>
    </div>
    <div class="footer-links friend-links">
      <span class="label">友情链接：</span>
      <a href="https://airporthub.pro/" target="_blank" rel="noopener" title="机场推荐科学上网教程">机场推荐科学上网教程</a>
      <a href="https://jichangxuanze.com/" target="_blank" rel="noopener" title="高性价比机场推荐指南">高性价比机场推荐指南</a>
    </div>
    <p>&copy; {currentYear} Orbit. All Rights Reserved.</p>
  </div>
</footer>

<style>
  .footer {
    padding: 3rem 0;
    margin-top: 4rem;
    border-top: 1px solid var(--card-border);
    text-align: center;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .footer-links a {
    color: var(--text-secondary);
    font-size: 0.85rem;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--text-primary);
  }

  .friend-links {
    margin-top: 0.5rem;
    margin-bottom: 1.5rem;
    gap: 1rem;
  }

  .friend-links .label {
    color: var(--text-secondary);
    font-size: 0.85rem;
  }

  .footer p {
    color: var(--text-secondary);
    font-size: 0.85rem;
    margin: 0;
  }
</style>
