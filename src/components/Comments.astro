<div class="comments-wrapper">
  <div class="giscus"></div>
</div>

<script is:inline>
  function loadGiscus() {
    const theme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
    const script = document.createElement('script');
    const repo = 'YOUR_GITHUB_NAME/YOUR_REPO_NAME';
    
    if (repo === 'YOUR_GITHUB_NAME/YOUR_REPO_NAME') {
      const commentsWrapper = document.querySelector('.giscus');
      if (commentsWrapper) {
        commentsWrapper.innerHTML = '<div style="text-align:center; padding: 2rem; color: var(--text-secondary); background: var(--card-bg); border-radius: var(--radius-md); border: 1px dashed var(--card-border); font-size: 0.9rem;">💬 评论区尚未配置，请参照 Giscus 官方文档获取你的仓库 ID，并修改 <code>src/components/Comments.astro</code></div>';
      }
      return;
    }

    script.src = 'https://giscus.app/client.js';
    script.setAttribute('data-repo', repo); 
    script.setAttribute('data-repo-id', 'YOUR_REPO_ID'); // TODO: 替换为真实的仓库 ID
    script.setAttribute('data-category', 'Announcements');
    script.setAttribute('data-category-id', 'YOUR_CATEGORY_ID'); // TODO: 替换为真实的分类 ID
    script.setAttribute('data-mapping', 'pathname');
    script.setAttribute('data-strict', '0');
    script.setAttribute('data-reactions-enabled', '1');
    script.setAttribute('data-emit-metadata', '0');
    script.setAttribute('data-input-position', 'bottom');
    script.setAttribute('data-theme', theme);
    script.setAttribute('data-lang', 'zh-CN');
    script.setAttribute('crossorigin', 'anonymous');
    script.async = true;

    const commentsWrapper = document.querySelector('.giscus');
    if (commentsWrapper) {
      commentsWrapper.innerHTML = '';
      commentsWrapper.appendChild(script);
    }
  }

  // Load immediately
  loadGiscus();

  // Handle View Transitions
  document.addEventListener('astro:after-swap', loadGiscus);

  // Watch for theme changes
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.attributeName === 'data-theme') {
        const theme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
        const iframe = document.querySelector('iframe.giscus-frame');
        if (!iframe) return;
        iframe.contentWindow.postMessage(
          { giscus: { setConfig: { theme } } },
          'https://giscus.app'
        );
      }
    });
  });

  observer.observe(document.documentElement, { attributes: true });
</script>

<style>
  .comments-wrapper {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--card-border);
  }
</style>
