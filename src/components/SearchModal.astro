---
<div id="search-modal" class="search-modal" style="display: none;">
  <div class="search-modal-backdrop"></div>
  <div class="search-modal-content">
    <div id="search-container"></div>
    <div class="close-hint">ESC 关闭</div>
  </div>
</div>

<script>
  let initialized = false;

  function initPagefind() {
    if (initialized) return;
    
    // Only init if we are on built site where pagefind exists
    // In dev mode, this will elegantly fail or log 404, which is expected
    const link = document.createElement('link');
    link.href = '/pagefind/pagefind-ui.css';
    link.rel = 'stylesheet';
    document.head.appendChild(link);

    const script = document.createElement('script');
    script.src = '/pagefind/pagefind-ui.js';
    script.onload = () => {
      // @ts-ignore
      if (window.PagefindUI) {
        // @ts-ignore
        new window.PagefindUI({ element: "#search-container", showSubResults: true, baseUrl: '/' });
        initialized = true;
      }
    };
    script.onerror = () => {
      document.getElementById('search-container').innerHTML = '<div style="padding: 2rem; text-align: center; color: var(--text-secondary);">搜索索引尚未生成。<br>请在本地执行 <code>npm run build</code> 后查看完整搜索效果。</div>';
    };
    document.head.appendChild(script);
  }

  function setupSearchModal() {
    const modal = document.getElementById('search-modal');
    const backdrop = document.querySelector('.search-modal-backdrop');

    if (!modal || !backdrop) return;

    const toggleModal = () => {
      if (modal.style.display === 'none') {
        modal.style.display = 'flex';
        initPagefind(); // Lazy load pagefind
        setTimeout(() => {
          const input = document.querySelector('.pagefind-ui__search-input');
          if (input) (input as HTMLElement).focus();
        }, 100);
      } else {
        modal.style.display = 'none';
      }
    };

    // Remove old listeners to prevent duplicates on view transition
    const handleKeydown = (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        toggleModal();
      }
      if (e.key === 'Escape' && modal.style.display === 'flex') {
        toggleModal();
      }
    };

    document.addEventListener('keydown', handleKeydown);
    backdrop.addEventListener('click', () => {
      modal.style.display = 'none';
    });
  }

  setupSearchModal();
  document.addEventListener('astro:after-swap', setupSearchModal);
</script>

<style>
  .search-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-top: 10vh;
  }

  .search-modal-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .search-modal-content {
    position: relative;
    width: 90%;
    max-width: 600px;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-hover);
    padding: 1.5rem;
    max-height: 80vh;
    overflow-y: auto;
    animation: modal-slide-down 0.2s ease-out;
  }

  @keyframes modal-slide-down {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .close-hint {
    text-align: center;
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--card-border);
  }

  /* Pagefind Dark Mode Overrides */
  :global([data-theme='dark']) {
    --pagefind-ui-primary: var(--accent-primary);
    --pagefind-ui-text: var(--text-primary);
    --pagefind-ui-background: var(--card-bg);
    --pagefind-ui-border: var(--card-border);
    --pagefind-ui-tag: rgba(255, 255, 255, 0.1);
  }
</style>
